---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
  navigation: Record<string, string>;
}

const { locale, navigation } = Astro.props;

const items = [
  { id: "about", label: navigation.about },
  { id: "research", label: navigation.research },
  { id: "team", label: navigation.team },
  { id: "publications", label: navigation.publications },
  { id: "services", label: navigation.services },
  { id: "contact", label: navigation.contact }
];
---

<header class="site-header" id="top">
  <div class="container header-inner">
    <a href={`/${locale}/`} class="brand">
      <span class="brand-mark">La</span>
      <span class="brand-copy">
        <strong>LaMoGe</strong>
        <small>IDEAN · UBA-CONICET</small>
      </span>
    </a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
      <span>{navigation.openMenu}</span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label={locale === "es" ? "Navegación principal" : "Main navigation"}>
      {items.map((item) => (
        <a href={`#${item.id}`}>{item.label}</a>
      ))}
      <LanguageSwitcher locale={locale} />
    </nav>
  </div>
</header>
