---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import HeroSection from "../../components/HeroSection.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Footer from "../../components/Footer.astro";
import activities from "../../data/activities.json";
import researchLines from "../../data/research-lines.json";
import team from "../../data/team.json";
import publications from "../../data/publications.json";
import services from "../../data/services.json";
import facilities from "../../data/facilities.json";
import gallery from "../../data/gallery.json";
import collaborations from "../../data/collaborations.json";
import teaching from "../../data/teaching.json";
import faq from "../../data/faq.json";
import { locales, localizeArray, localizeText, siteContent, type Locale } from "../../lib/i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;

if (!locales.includes(locale)) {
  return Astro.redirect("/es/");
}

const content = siteContent[locale];
const roleOptions = Array.from(new Set(team.map((member) => member.category)));
const publicationYears = Array.from(new Set(publications.map((publication) => publication.year))).sort((a, b) => b - a);
const publicationTopics = Array.from(new Set(publications.map((publication) => publication.topic)));
const publicationTypes = Array.from(new Set(publications.map((publication) => publication.type)));

const roleLabels: Record<string, Record<Locale, string>> = {
  leadership: { es: "Dirección", en: "Leadership" },
  researchers: { es: "Investigadores", en: "Researchers" },
  fellows: { es: "Becarios", en: "Fellows" },
  students: { es: "Estudiantes", en: "Students" },
  collaborators: { es: "Colaboradores", en: "Collaborators" }
};
---

<BaseLayout title={content.meta.title} description={content.meta.description} locale={locale}>
  <Header locale={locale} navigation={content.navigation} />
  <HeroSection hero={content.hero} />

  <main>
    {content.sectionOrder.map((sectionKey) => (
      <>
        {sectionKey === "about" && (
          <section id="about" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.about.eyebrow} title={content.about.title} description={content.about.description} />
              <div class="about-grid">
                <article class="info-card" data-reveal>
                  <p class="eyebrow">{content.about.missionTitle}</p>
                  <h3>{content.about.missionTitle}</h3>
                  <p>{content.about.mission}</p>
                </article>
                <article class="info-card" data-reveal>
                  <p class="eyebrow">{content.about.visionTitle}</p>
                  <h3>{content.about.visionTitle}</h3>
                  <p>{content.about.vision}</p>
                </article>
                <article class="info-card" data-reveal>
                  <p class="eyebrow">{content.about.institutionTitle}</p>
                  <h3>{content.about.institutionTitle}</h3>
                  <p>{content.about.institution}</p>
                </article>
                <article class="info-card" data-reveal>
                  <p class="eyebrow">{content.about.historyTitle}</p>
                  <h3>{content.about.historyTitle}</h3>
                  <p>{content.about.history}</p>
                </article>
              </div>
            </div>
          </section>
        )}

        {sectionKey === "activities" && (
          <section id="activities" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.activities.eyebrow} title={content.activities.title} description={content.activities.description} />
              <div class="activity-grid">
                {activities.map((item) => (
                  <article class="feature-card" data-reveal>
                    <span class="icon-chip" aria-hidden="true">{item.icon}</span>
                    <h3>{localizeText(item.title, locale)}</h3>
                    <p>{localizeText(item.description, locale)}</p>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "research" && (
          <section id="research" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.research.eyebrow} title={content.research.title} description={content.research.description} />
              <div class="research-grid">
                {researchLines.map((line) => (
                  <article class="feature-card" data-reveal>
                    <img src={line.image} alt="" />
                    <h3>{localizeText(line.title, locale)}</h3>
                    <p>{localizeText(line.summary, locale)}</p>
                    <ul class="tag-list">
                      {localizeArray(line.keywords, locale).map((keyword) => (
                        <li>{keyword}</li>
                      ))}
                    </ul>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "team" && (
          <section id="team" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.team.eyebrow} title={content.team.title} description={content.team.description} />

              <div class="filter-row">
                <div class="filter-group">
                  <label for="team-filter">{content.team.filterLabel}</label>
                  <select id="team-filter" data-team-filter>
                    <option value="">{content.team.allRoles}</option>
                    {roleOptions.map((role) => (
                      <option value={role}>{localizeText(roleLabels[role] ?? { es: role, en: role }, locale)}</option>
                    ))}
                  </select>
                </div>
              </div>

              <div class="team-grid">
                {team.map((member) => (
                  <article class="person-card" data-reveal data-team-member data-category={member.category}>
                    <img src={member.photo} alt={member.name} />
                    <p class="role">{localizeText(member.role, locale)}</p>
                    <h3>{member.name}</h3>
                    <div class="meta">
                      <span>{member.affiliation}</span>
                      <span>{localizeText(member.area, locale)}</span>
                      {member.email && <a href={`mailto:${member.email}`}>{member.email}</a>}
                    </div>
                    {member.links.length > 0 && (
                      <ul class="link-list">
                        {member.links.map((link) => (
                          <li><a href={link.url} target="_blank" rel="noreferrer">{link.label}</a></li>
                        ))}
                      </ul>
                    )}
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "publications" && (
          <section id="publications" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.publications.eyebrow} title={content.publications.title} description={content.publications.description} />

              <div class="filter-row filter-bar" data-filter-target="#publication-list">
                <div class="filter-group">
                  <label for="publication-year">{content.publications.filterYear}</label>
                  <select id="publication-year">
                    <option value="">{content.publications.allYears}</option>
                    {publicationYears.map((year) => (
                      <option value={String(year)}>{year}</option>
                    ))}
                  </select>
                </div>
                <div class="filter-group">
                  <label for="publication-topic">{content.publications.filterTopic}</label>
                  <select id="publication-topic">
                    <option value="">{content.publications.allTopics}</option>
                    {publicationTopics.map((topic) => (
                      <option value={topic}>{topic}</option>
                    ))}
                  </select>
                </div>
                <div class="filter-group">
                  <label for="publication-type">{content.publications.filterType}</label>
                  <select id="publication-type">
                    <option value="">{content.publications.allTypes}</option>
                    {publicationTypes.map((type) => (
                      <option value={type}>{type}</option>
                    ))}
                  </select>
                </div>
              </div>

              <div id="publication-list" class="publications-grid">
                {publications.map((publication) => (
                  <article
                    class="publication-card"
                    data-reveal
                    data-publication
                    data-year={String(publication.year)}
                    data-topic={publication.topic}
                    data-type={publication.type}
                  >
                    <div class="publication-meta">
                      <span class="status-chip">{publication.year}</span>
                      <span class="status-chip">{publication.type}</span>
                      <span class="status-chip">{publication.topic}</span>
                      {publication.featured && <span class="status-chip featured-chip">{content.publications.featuredLabel}</span>}
                    </div>
                    <h3>{publication.title}</h3>
                    <p>{publication.authors}</p>
                    <p>{publication.journal}</p>
                    {publication.doi && <p>DOI: {publication.doi}</p>}
                    <a href={publication.url} target="_blank" rel="noreferrer">Link</a>
                  </article>
                ))}
              </div>

              <div class="hero-actions">
                <a class="button button-secondary" href="#contact">{content.publications.viewAll}</a>
              </div>
            </div>
          </section>
        )}

        {sectionKey === "services" && (
          <section id="services" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.services.eyebrow} title={content.services.title} description={content.services.description} />
              <div class="services-grid">
                {services.map((service) => (
                  <article class="feature-card" data-reveal>
                    <h3>{localizeText(service.title, locale)}</h3>
                    <p>{localizeText(service.summary, locale)}</p>
                    <div class="service-meta">
                      <span><strong>{locale === "es" ? "Dirigido a:" : "For:"}</strong> {localizeText(service.audience, locale)}</span>
                      <span><strong>{locale === "es" ? "Estado:" : "Status:"}</strong> {localizeText(service.status, locale)}</span>
                    </div>
                    <ul class="tag-list">
                      {localizeArray(service.applications, locale).map((application) => (
                        <li>{application}</li>
                      ))}
                    </ul>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "facilities" && (
          <section id="facilities" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.facilities.eyebrow} title={content.facilities.title} description={content.facilities.description} />
              <div class="facilities-grid">
                {facilities.map((item) => (
                  <article class="feature-card" data-reveal>
                    <img src={item.image} alt="" />
                    <h3>{localizeText(item.name, locale)}</h3>
                    <div class="facility-meta">
                      <span><strong>{locale === "es" ? "Categoría:" : "Category:"}</strong> {localizeText(item.category, locale)}</span>
                      <span><strong>{locale === "es" ? "Uso:" : "Use:"}</strong> {localizeText(item.use, locale)}</span>
                    </div>
                    <p>{localizeText(item.description, locale)}</p>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "gallery" && (
          <section id="gallery" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.gallery.eyebrow} title={content.gallery.title} description={content.gallery.description} />
              <div class="gallery-grid">
                {gallery.map((item) => (
                  <article class="gallery-card" data-reveal>
                    <span class="status-chip media-type">{item.type}</span>
                    <img src={item.asset} alt={localizeText(item.title, locale)} />
                    <div class="feature-card">
                      <h3>{localizeText(item.title, locale)}</h3>
                      <p>{localizeText(item.caption, locale)}</p>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "collaborations" && (
          <section id="collaborations" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.collaborations.eyebrow} title={content.collaborations.title} description={content.collaborations.description} />
              <div class="collaboration-grid">
                {collaborations.map((item) => (
                  <article class="collab-card" data-reveal>
                    <img src={item.logo} alt={`${item.name} logo`} />
                    <h3>{item.name}</h3>
                    <div class="collab-meta">
                      <span><strong>{locale === "es" ? "Tipo:" : "Kind:"}</strong> {localizeText(item.kind, locale)}</span>
                      <span><strong>{locale === "es" ? "Escala:" : "Scope:"}</strong> {localizeText(item.scope, locale)}</span>
                    </div>
                    <p>{localizeText(item.summary, locale)}</p>
                    <a href={item.url} target="_blank" rel="noreferrer">{locale === "es" ? "Visitar" : "Visit"}</a>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "teaching" && (
          <section id="teaching" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.teaching.eyebrow} title={content.teaching.title} description={content.teaching.description} />
              <div class="teaching-grid">
                {teaching.map((item) => (
                  <article class="info-card" data-reveal>
                    <p class="eyebrow">{localizeText(item.format, locale)}</p>
                    <h3>{localizeText(item.title, locale)}</h3>
                    <p>{localizeText(item.description, locale)}</p>
                    <p><strong>{locale === "es" ? "Destinatarios:" : "Audience:"}</strong> {localizeText(item.audience, locale)}</p>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "faq" && (
          <section id="faq" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.faq.eyebrow} title={content.faq.title} description={content.faq.description} />
              <div class="faq-grid">
                {faq.map((item) => (
                  <article class="info-card" data-reveal>
                    <h3>{localizeText(item.question, locale)}</h3>
                    <p>{localizeText(item.answer, locale)}</p>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {sectionKey === "contact" && (
          <section id="contact" class="section container">
            <div class="panel">
              <SectionHeader eyebrow={content.contact.eyebrow} title={content.contact.title} description={content.contact.description} />
              <div class="contact-grid">
                <aside class="contact-card" data-reveal>
                  <p><strong>{content.contact.emailLabel}</strong>{content.contact.email}</p>
                  <p><strong>{content.contact.addressLabel}</strong>{content.contact.address}</p>
                  <p><strong>{content.contact.affiliationLabel}</strong>{content.contact.affiliation}</p>
                  <div class="hero-actions">
                    <a class="button button-primary" href={`mailto:${content.contact.email}`}>Email</a>
                    <a class="button button-secondary" href="https://maps.google.com/" target="_blank" rel="noreferrer">Map</a>
                  </div>
                </aside>

                <div class="contact-form" data-reveal>
                  <p>{content.contact.formNote}</p>
                  <form>
                    <div class="field-grid">
                      <label>
                        <span>{content.contact.formName}</span>
                        <input name="name" type="text" placeholder={content.contact.formName} />
                      </label>
                      <label>
                        <span>{content.contact.formEmail}</span>
                        <input name="email" type="email" placeholder="nombre@institucion.org" />
                      </label>
                    </div>
                    <label>
                      <span>{content.contact.formOrganization}</span>
                      <input name="organization" type="text" placeholder={content.contact.formOrganization} />
                    </label>
                    <label>
                      <span>{content.contact.formMessage}</span>
                      <textarea name="message" placeholder={content.contact.formMessage}></textarea>
                    </label>
                    <button class="button button-primary" type="submit">{content.contact.formSubmit}</button>
                  </form>
                </div>
              </div>
            </div>
          </section>
        )}
      </>
    ))}
  </main>

  <Footer locale={locale} navigation={content.navigation} footer={content.footer} />
</BaseLayout>
