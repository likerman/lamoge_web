---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import activitiesData from "../../data/activities.json";
import servicesData from "../../data/services.json";
import { locales, localizeArray, localizeText, siteContent, type Locale } from "../../lib/i18n";
import type { ActivityItem, ServiceItem } from "../../types/content";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const content = siteContent[locale];
const activities = activitiesData as ActivityItem[];
const services = (servicesData as ServiceItem[]).slice(0, 3);

const copy = {
  es: {
    title: "¿Qué hacemos? | LaMoGe",
    description: "Metodologías, líneas de trabajo y modalidades de articulación del laboratorio.",
    eyebrow: "¿Quiénes somos?",
    pageTitle: "¿Qué hacemos?",
    pageDescription:
      "LaMoGe trabaja sobre problemas geológicos complejos mediante metodologías integradas que combinan observación, experimentación, simulación y análisis estructural.",
    servicesTitle: "Aplicaciones y articulación"
  },
  en: {
    title: "What we do | LaMoGe",
    description: "Methodologies, working lines and modes of institutional articulation of the laboratory.",
    eyebrow: "Who we are",
    pageTitle: "What we do",
    pageDescription:
      "LaMoGe addresses complex geological problems through integrated methodologies that combine observation, experimentation, simulation and structural analysis.",
    servicesTitle: "Applications and articulation"
  }
}[locale];
---

<BaseLayout title={copy.title} description={copy.description} locale={locale} image="/images/gallery/DSC_0134.JPG">
  <Header locale={locale} navigation={content.navigation} />
  <main id="main-content" class="pb-14">
    <PageHero eyebrow={copy.eyebrow} title={copy.pageTitle} description={copy.pageDescription} image="/images/gallery/DSC_0134.JPG" />

    <section class="section shell">
      <div class="surface-panel">
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {activities.map((item) => (
            <article class="card" data-reveal>
              <span class="pill">{item.icon}</span>
              <h2 class="mt-4 text-lg font-semibold text-[color:var(--ink-950)]">{localizeText(item.title, locale)}</h2>
              <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.description, locale)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section shell">
      <div class="surface-panel surface-panel-dark">
        <p class="eyebrow">{copy.servicesTitle}</p>
        <div class="grid gap-4 lg:grid-cols-3">
          {services.map((item) => (
            <article class="card-dark" data-reveal>
              <span class="pill !bg-white/6 !border-white/8 !text-white/80">{localizeText(item.status, locale)}</span>
              <h3 class="mt-4 text-lg font-semibold text-white">{localizeText(item.title, locale)}</h3>
              <p class="mt-3 text-sm leading-7 text-white/75">{localizeText(item.summary, locale)}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {localizeArray(item.applications, locale).slice(0, 3).map((entry) => (
                  <span class="pill !bg-white/6 !border-white/8 !text-white/80">{entry}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} navigation={content.navigation} footer={content.footer} />
</BaseLayout>
