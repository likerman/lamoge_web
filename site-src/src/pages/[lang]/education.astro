---
import RedirectPage from "../../components/RedirectPage.astro";
import { locales, type Locale } from "../../lib/i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
---

<RedirectPage locale={locale} to="/doctoral/" title={locale === "es" ? "Redireccionando a Doctorandos" : "Redirecting to Doctoral fellows"} />
