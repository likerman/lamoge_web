---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import projectsData from "../../data/projects.json";
import collaborationsData from "../../data/collaborations.json";
import { locales, localizeArray, localizeText, siteContent, type Locale } from "../../lib/i18n";
import type { CollaborationItem, ProjectItem } from "../../types/content";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;

const content = siteContent[locale];
const projects = projectsData as ProjectItem[];
const collaborations = collaborationsData as CollaborationItem[];

const copy = {
  es: {
    title: "Proyectos | LaMoGe",
    description: "Proyectos activos, áreas de aplicación y red de colaboraciones del laboratorio.",
    eyebrow: "Proyectos",
    pageTitle: "Proyectos que estructuran la agenda aplicada y la cooperación científica del laboratorio.",
    pageDescription:
      "La sección de proyectos organiza prioridades de investigación, campos de aplicación, socios institucionales y ejes temáticos en un formato preparado para actualización continua.",
    collaborationsTitle: "Instituciones asociadas"
  },
  en: {
    title: "Projects | LaMoGe",
    description: "Active projects, application areas and the laboratory’s collaboration network.",
    eyebrow: "Projects",
    pageTitle: "Projects that structure the laboratory’s applied agenda and scientific cooperation.",
    pageDescription:
      "The projects section presents research priorities, application fields, institutional partners and thematic axes in a format prepared for ongoing updates.",
    collaborationsTitle: "Associated institutions"
  }
}[locale];
---

<BaseLayout title={copy.title} description={copy.description} locale={locale} image="/images/gallery/DJI_0754.JPG">
  <Header locale={locale} navigation={content.navigation} />
  <main id="main-content" class="pb-14">
    <PageHero eyebrow={copy.eyebrow} title={copy.pageTitle} description={copy.pageDescription} image="/images/gallery/DJI_0754.JPG" />

    <section class="section shell">
      <div class="surface-panel">
        <div class="grid gap-5 xl:grid-cols-2">
          {projects.map((item) => (
            <article class="card overflow-hidden p-0" data-reveal>
              {item.image && <img src={item.image} alt="" class="aspect-[16/10] w-full object-cover" />}
              <div class="p-6">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="pill">{localizeText(item.status, locale)}</span>
                  <span class="pill">{item.period}</span>
                </div>
                <h2 class="mt-4 text-2xl font-semibold text-[color:var(--ink-950)]">{localizeText(item.title, locale)}</h2>
                <p class="mt-4 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.summary, locale)}</p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {localizeArray(item.tags, locale).map((tag) => (
                    <span class="pill">{tag}</span>
                  ))}
                </div>
                <p class="mt-5 text-sm text-[color:var(--ink-500)]">{item.partners.join(" · ")}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section shell">
      <div class="surface-panel">
        <p class="eyebrow">{copy.collaborationsTitle}</p>
        <div class="grid gap-5 lg:grid-cols-2">
          {collaborations.map((item) => (
            <article class="card" data-reveal>
              <h3 class="text-xl font-semibold text-[color:var(--ink-950)]">{item.name}</h3>
              <p class="mt-2 text-sm font-semibold text-[color:var(--accent-strong)]">{localizeText(item.kind, locale)}</p>
              <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.summary, locale)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} navigation={content.navigation} footer={content.footer} />
</BaseLayout>
