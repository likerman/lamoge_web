---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import teachingData from "../../data/teaching.json";
import faqData from "../../data/faq.json";
import { locales, localizeText, siteContent, type Locale } from "../../lib/i18n";
import type { FaqItem, TeachingItem } from "../../types/content";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const content = siteContent[locale];
const teaching = teachingData as TeachingItem[];
const faq = (faqData as FaqItem[]).slice(1, 3);

const copy = {
  es: {
    title: "Cursos | LaMoGe",
    description: "Cursos, capacitación y actualización metodológica del laboratorio.",
    eyebrow: "Formación",
    pageTitle: "Cursos",
    pageDescription:
      "LaMoGe ofrece instancias de formación metodológica y actualización académica en geología estructural, modelado y herramientas cuantitativas.",
    faqTitle: "Preguntas frecuentes"
  },
  en: {
    title: "Courses | LaMoGe",
    description: "Courses, training activities and methodological updating from the laboratory.",
    eyebrow: "Training",
    pageTitle: "Courses",
    pageDescription:
      "LaMoGe offers methodological training and academic updating focused on structural geology, modelling and quantitative tools.",
    faqTitle: "Frequently asked questions"
  }
}[locale];
---

<BaseLayout title={copy.title} description={copy.description} locale={locale} image="/images/gallery/DSC_0450.JPG">
  <Header locale={locale} navigation={content.navigation} />
  <main id="main-content" class="pb-14">
    <PageHero eyebrow={copy.eyebrow} title={copy.pageTitle} description={copy.pageDescription} image="/images/gallery/DSC_0450.JPG" />

    <section class="section shell">
      <div class="surface-panel">
        <div class="grid gap-5 lg:grid-cols-3">
          {teaching.map((item) => (
            <article class="card" data-reveal>
              <span class="pill">{localizeText(item.format, locale)}</span>
              <h2 class="mt-4 text-xl font-semibold text-[color:var(--ink-950)]">{localizeText(item.title, locale)}</h2>
              <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.description, locale)}</p>
              <p class="mt-4 text-sm text-[color:var(--ink-500)]">{localizeText(item.audience, locale)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section shell">
      <div class="surface-panel">
        <p class="eyebrow">{copy.faqTitle}</p>
        <div class="grid gap-4">
          {faq.map((item) => (
            <details class="card" data-reveal>
              <summary class="cursor-pointer list-none text-lg font-semibold text-[color:var(--ink-950)]">{localizeText(item.question, locale)}</summary>
              <p class="mt-4 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.answer, locale)}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} navigation={content.navigation} footer={content.footer} />
</BaseLayout>
