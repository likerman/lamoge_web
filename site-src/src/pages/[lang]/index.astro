---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import HeroSection from "../../components/HeroSection.astro";
import Footer from "../../components/Footer.astro";
import facilitiesData from "../../data/facilities.json";
import activitiesData from "../../data/activities.json";
import newsData from "../../data/news.json";
import collaborationsData from "../../data/collaborations.json";
import { locales, localizeText, siteContent, type Locale } from "../../lib/i18n";
import type { ActivityItem, CollaborationItem, FacilityItem, NewsItem } from "../../types/content";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const content = siteContent[locale];

const facilities = (facilitiesData as FacilityItem[]).slice(0, 3);
const activities = (activitiesData as ActivityItem[]).slice(0, 3);
const news = [...(newsData as NewsItem[])].sort((a, b) => b.date.localeCompare(a.date)).slice(0, 3);
const collaborations = (collaborationsData as CollaborationItem[]).slice(0, 4);

const copy = {
  es: {
    title: "LaMoGe | Laboratorio de Modelado Geológico",
    description:
      "Portal institucional bilingüe del Laboratorio de Modelado Geológico con información institucional, capacidades y noticias.",
    identityEyebrow: "¿Qué es el LaMoGe?",
    identityTitle: "Una plataforma académica para modelado geológico, tectónica y análisis estructural.",
    identityBody:
      "LaMoGe es un laboratorio de investigación articulado entre IDEAN, UBA y CONICET. Integra observaciones de campo, modelado análogo, simulación numérica y análisis cuantitativo para estudiar sistemas geológicos complejos, formar recursos humanos y sostener una agenda científica de alto nivel.",
    identityPoints: [
      "Trayectoria académica e institucional consolidada",
      "Trabajo interdisciplinario entre investigación, docencia y soporte metodológico",
      "Proyección regional e internacional en problemas geológicos complejos"
    ],
    networkTitle: "Inserción institucional",
    capabilitiesEyebrow: "Capacidades",
    capabilitiesTitle: "Capacidades experimentales, metodológicas y computacionales",
    capabilitiesBody:
      "La plataforma institucional resume infraestructura, recursos de análisis y capacidades aplicadas del laboratorio para investigación, servicios y colaboración externa.",
    capabilitiesCta: "Ver capacidades",
    newsEyebrow: "Noticias",
    newsTitle: "Actualidad institucional y novedades científicas",
    newsBody:
      "Noticias, anuncios y novedades editoriales del laboratorio en un formato simple de actualizar.",
    newsCta: "Ver noticias",
    emptyNews: "No hay noticias publicadas por el momento."
  },
  en: {
    title: "LaMoGe | Geological Modelling Laboratory",
    description:
      "Bilingual institutional portal of the Geological Modelling Laboratory with institutional information, capabilities and news.",
    identityEyebrow: "What is LaMoGe?",
    identityTitle: "An academic platform for geological modelling, tectonics and structural analysis.",
    identityBody:
      "LaMoGe is a research laboratory articulated across IDEAN, UBA and CONICET. It combines field observations, analogue modelling, numerical simulation and quantitative analysis to study complex geological systems, train researchers and sustain a high-level scientific agenda.",
    identityPoints: [
      "Consolidated academic and institutional trajectory",
      "Interdisciplinary work across research, teaching and methodological support",
      "Regional and international projection on complex geological problems"
    ],
    networkTitle: "Institutional embedding",
    capabilitiesEyebrow: "Capabilities",
    capabilitiesTitle: "Experimental, methodological and computational capabilities",
    capabilitiesBody:
      "The institutional platform summarises the laboratory’s infrastructure, analysis resources and applied capabilities for research, services and external collaboration.",
    capabilitiesCta: "View capabilities",
    newsEyebrow: "News",
    newsTitle: "Institutional updates and scientific news",
    newsBody:
      "News, announcements and editorial updates from the laboratory in a format that is simple to maintain.",
    newsCta: "View news",
    emptyNews: "There are no published news items at the moment."
  }
}[locale];
---

<BaseLayout title={copy.title} description={copy.description} locale={locale} image="/images/gallery/DJI_0664.JPG">
  <Header locale={locale} navigation={content.navigation} />

  <HeroSection locale={locale} hero={content.hero} />

  <main id="main-content" class="pb-24">
    <section class="section shell">
      <div class="surface-panel grid gap-10 xl:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]">
        <div data-reveal>
          <p class="eyebrow">{copy.identityEyebrow}</p>
          <h2 class="section-title">{copy.identityTitle}</h2>
          <p class="section-copy">{copy.identityBody}</p>

          <ul class="mt-8 grid gap-4">
            {copy.identityPoints.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-cyan-500/10 text-cyan-600">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7"></path>
                  </svg>
                </span>
                <span class="text-sm leading-7 text-[color:var(--ink-700)]">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="grid gap-4" data-reveal>
          <article class="card overflow-hidden p-0">
            <img src="/images/gallery/DJI_0754.JPG" alt="LaMoGe" class="aspect-[4/3] w-full object-cover" />
          </article>
          <article class="card">
            <p class="eyebrow">{copy.networkTitle}</p>
            <div class="grid gap-3">
              {collaborations.map((item) => (
                <div class="flex items-center justify-between gap-4 border-b border-ink-100 pb-3 last:border-b-0 last:pb-0">
                  <div>
                    <h3 class="font-semibold text-[color:var(--ink-950)]">{item.name}</h3>
                    <p class="text-sm text-[color:var(--ink-500)]">{localizeText(item.kind, locale)}</p>
                  </div>
                  {item.logo && <img src={item.logo} alt={item.name} class="h-10 w-auto grayscale opacity-75" />}
                </div>
              ))}
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section shell" id="capabilities">
      <div class="surface-panel">
        <div class="flex flex-wrap items-end justify-between gap-6">
          <div>
            <p class="eyebrow">{copy.capabilitiesEyebrow}</p>
            <h2 class="section-title">{copy.capabilitiesTitle}</h2>
            <p class="section-copy">{copy.capabilitiesBody}</p>
          </div>
          <a href={`/${locale}/capabilities/`} class="button-light">{copy.capabilitiesCta}</a>
        </div>

        <div class="mt-10 grid gap-5 xl:grid-cols-3">
          {facilities.map((item) => (
            <article class="card" data-reveal>
              <span class="pill">{localizeText(item.category, locale)}</span>
              <h3 class="mt-4 text-xl font-semibold text-[color:var(--ink-950)]">{localizeText(item.name, locale)}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.description, locale)}</p>
            </article>
          ))}
        </div>

        <div class="mt-5 grid gap-5 xl:grid-cols-3">
          {activities.map((item) => (
            <article class="card" data-reveal>
              <span class="pill">{item.icon}</span>
              <h3 class="mt-4 text-xl font-semibold text-[color:var(--ink-950)]">{localizeText(item.title, locale)}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.description, locale)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section shell" id="news">
      <div class="surface-panel">
        <div class="flex flex-wrap items-end justify-between gap-6">
          <div>
            <p class="eyebrow">{copy.newsEyebrow}</p>
            <h2 class="section-title">{copy.newsTitle}</h2>
            <p class="section-copy">{copy.newsBody}</p>
          </div>
          <a href={`/${locale}/news/`} class="button-light">{copy.newsCta}</a>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {news.map((item) => (
            <article class="card" data-reveal>
              <div class="flex flex-wrap items-center gap-3">
                <span class="pill">{localizeText(item.category, locale)}</span>
                <time class="text-sm text-[color:var(--ink-500)]">
                  {new Date(`${item.date}T00:00:00`).toLocaleDateString(locale === "es" ? "es-AR" : "en-GB", {
                    year: "numeric",
                    month: "long",
                    day: "numeric"
                  })}
                </time>
              </div>
              <h3 class="mt-4 text-xl font-semibold text-[color:var(--ink-950)]">{localizeText(item.title, locale)}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.summary, locale)}</p>
              {item.url && (
                <a
                  href={item.url}
                  target={item.url.startsWith("http") ? "_blank" : undefined}
                  rel={item.url.startsWith("http") ? "noreferrer" : undefined}
                  class="mt-5 inline-flex text-sm font-semibold text-[color:var(--accent-strong)]"
                >
                  {locale === "es" ? "Ver más" : "Read more"}
                </a>
              )}
            </article>
          ))}

          {news.length === 0 && (
            <article class="card lg:col-span-3" data-reveal>
              <p class="text-sm leading-7 text-[color:var(--ink-700)]">{copy.emptyNews}</p>
            </article>
          )}
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} navigation={content.navigation} footer={content.footer} />
</BaseLayout>
