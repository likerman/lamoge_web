---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import { locales, localizeArray, localizeText, siteContent, type Locale } from "../../lib/i18n";
import type { ProjectItem, Publication, ResearchLine } from "../../types/content";
import researchLinesData from "../../data/research-lines.json";
import projectsData from "../../data/projects.json";
import publicationsData from "../../data/publications.json";
import servicesData from "../../data/services.json";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const content = siteContent[locale];
const researchLines = researchLinesData as ResearchLine[];
const projects = projectsData as ProjectItem[];
const services = servicesData as any[];
const allPublications = publicationsData as Publication[];

const copy = {
  es: {
    title: "Investigación | LaMoGe",
    description: "Líneas de investigación, capacidades metodológicas y producción científica del laboratorio.",
    eyebrow: "Investigación",
    pageTitle: "Líneas de trabajo, proyectos y producción científica",
    pageDescription: "La investigación en LaMoGe articula observaciones de campo, experimentación física y simulación numérica para abordar problemas estructurales y geodinámicos complejos.",
    capabilitiesTitle: "Capacidades e infraestructura",
    projectsTitle: "Proyectos de Investigación",
    publicationsTitle: "Publicaciones Científicas",
    searchPlaceholder: "Filtrar por autor, año, tema o revista...",
    noResults: "No se encontraron publicaciones con esos criterios."
  },
  en: {
    title: "Research | LaMoGe",
    description: "Research lines, methodological capabilities and scientific production of the laboratory.",
    eyebrow: "Research",
    pageTitle: "Research lines, projects and scientific output",
    pageDescription: "Research at LaMoGe connects field observations, physical experimentation and numerical simulation to address complex structural and geodynamic problems.",
    capabilitiesTitle: "Capabilities and infrastructure",
    projectsTitle: "Research Projects",
    publicationsTitle: "Scientific Publications",
    searchPlaceholder: "Filter by author, year, topic or journal...",
    noResults: "No publications found with those criteria."
  }
}[locale];
---

<BaseLayout title={copy.title} description={copy.description} locale={locale} image="/images/gallery/IMG_20240418_114316134.jpg">
  <Header locale={locale} navigation={content.navigation} />
  <main id="main-content" class="pb-24">
    <PageHero eyebrow={copy.eyebrow} title={copy.pageTitle} description={copy.pageDescription} image="/images/gallery/IMG_20240418_114316134.jpg" />

    <!-- SECCIÓN: LÍNEAS DE INVESTIGACIÓN -->
    <section class="section shell" id="lines">
      <div class="surface-panel">
        <p class="eyebrow">{locale === "es" ? "Áreas de estudio" : "Study Areas"}</p>
        <h2 class="section-title mb-8">{locale === "es" ? "Líneas de Investigación" : "Research Lines"}</h2>
        <div class="grid gap-6 xl:grid-cols-2">
          {researchLines.map((line) => (
            <article class="card overflow-hidden p-0 group" data-reveal>
              <div class="p-8">
                <h3 class="text-2xl font-bold text-ink-950 group-hover:text-teal-600 transition-colors">{localizeText(line.title, locale)}</h3>
                <p class="mt-4 text-sm leading-relaxed text-ink-700">{localizeText(line.summary, locale)}</p>
                <div class="mt-6 flex flex-wrap gap-2">
                  {localizeArray(line.keywords, locale).map((keyword) => (
                    <span class="text-[0.65rem] font-bold uppercase tracking-wider text-teal-600/80 bg-teal-500/5 px-2 py-1 rounded-md">{keyword}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SECCIÓN: SERVICIOS AL MEDIO -->
    <section class="section shell" id="services">
      <div class="surface-panel">
        <p class="eyebrow">{locale === "es" ? "Vinculación" : "Outreach"}</p>
        <h2 class="section-title mb-10">{locale === "es" ? "Servicios y articulación externa" : "Services and external collaboration"}</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {services.map((service) => (
            <div class="card bg-white/40" data-reveal>
              <h4 class="font-bold text-ink-950">{localizeText(service.title, locale)}</h4>
              <p class="mt-2 text-sm text-ink-600 line-clamp-4">{localizeText(service.summary, locale)}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SECCIÓN: PROYECTOS -->
    <section class="section shell" id="projects">
      <div class="surface-panel">
        <p class="eyebrow">{locale === "es" ? "Financiamiento" : "Funding"}</p>
        <h2 class="section-title mb-10">{copy.projectsTitle}</h2>
        <div class="grid gap-4">
          {projects.map((project) => (
            <article class="card flex flex-col md:flex-row md:items-center justify-between gap-6" data-reveal>
              <div class="max-w-3xl">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-[0.6rem] font-bold uppercase tracking-widest bg-ink-950 text-white px-2 py-0.5 rounded">{project.period}</span>
                  <span class="text-[0.6rem] font-bold uppercase tracking-widest text-teal-600">{localizeText(project.status, locale)}</span>
                </div>
                <h3 class="text-lg font-bold text-ink-950">{localizeText(project.title, locale)}</h3>
                <p class="mt-1 text-sm text-ink-700 leading-relaxed">{localizeText(project.summary, locale)}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                   {project.partners.map(partner => (
                     <span class="text-[0.6rem] font-semibold text-ink-500 uppercase tracking-tighter">· {partner}</span>
                   ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SECCIÓN: PUBLICACIONES CON BUSCADOR -->
    <section class="section shell" id="publications">
      <div class="surface-panel">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
          <div>
            <p class="eyebrow">{locale === "es" ? "Producción" : "Output"}</p>
            <h2 class="section-title">{copy.publicationsTitle}</h2>
          </div>
          <div class="relative w-full max-w-md">
            <input 
              type="text" 
              id="pub-search" 
              placeholder={copy.searchPlaceholder}
              class="w-full rounded-2xl border border-ink-200 bg-white px-6 py-3 text-sm focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-500/10 transition-all shadow-sm"
            />
            <span class="absolute right-6 top-1/2 -translate-y-1/2 text-ink-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </span>
          </div>
        </div>

        <div id="pub-list" class="grid gap-3">
          {allPublications.map((pub) => (
            <article class="pub-item card !py-4 transition-all hover:bg-mist-50" data-reveal
              data-search={`${pub.title} ${pub.authors} ${pub.journal} ${pub.year} ${pub.topics?.join(' ')}`.toLowerCase()}
            >
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-1">
                    <span class="text-[0.65rem] font-bold text-teal-600">{pub.year}</span>
                    <span class="h-1 w-1 rounded-full bg-ink-200"></span>
                    <span class="text-[0.65rem] font-bold text-ink-500 uppercase tracking-widest">{pub.journal}</span>
                  </div>
                  <h3 class="text-sm font-bold text-ink-950 leading-snug">{pub.title}</h3>
                  <p class="mt-1 text-xs text-ink-600 italic">{pub.authors}</p>
                </div>
                {pub.doi && (
                  <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noopener noreferrer" class="button-light !py-2 !px-4 !text-xs shrink-0">
                    DOI
                  </a>
                )}
              </div>
            </article>
          ))}
          <div id="no-results" class="hidden py-20 text-center">
            <p class="text-ink-500 italic">{copy.noResults}</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const searchInput = document.getElementById('pub-search') as HTMLInputElement;
    const pubItems = document.querySelectorAll('.pub-item');
    const noResults = document.getElementById('no-results');

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase();
        let visibleCount = 0;

        pubItems.forEach(item => {
          const searchData = (item as HTMLElement).dataset.search || '';
          if (searchData.includes(query)) {
            (item as HTMLElement).classList.remove('hidden');
            visibleCount++;
          } else {
            (item as HTMLElement).classList.add('hidden');
          }
        });

        if (noResults) {
          if (visibleCount === 0) noResults.classList.remove('hidden');
          else noResults.classList.add('hidden');
        }
      });
    }
  </script>

  <Footer locale={locale} navigation={content.navigation} footer={content.footer} />
</BaseLayout>
