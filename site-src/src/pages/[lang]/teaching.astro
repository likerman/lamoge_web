---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import teachingData from "../../data/teaching.json";
import { locales, localizeText, siteContent, type Locale } from "../../lib/i18n";
import type { TeachingItem } from "../../types/content";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const content = siteContent[locale];
const teaching = teachingData as TeachingItem[];

const copy = {
  es: {
    title: "Docencia | LaMoGe",
    description: "Participación del laboratorio en docencia universitaria y formación avanzada.",
    eyebrow: "Formación",
    pageTitle: "Docencia",
    pageDescription:
      "La actividad docente de LaMoGe se articula con formación de grado, posgrado, dirección de tesis y acompañamiento metodológico en geociencias."
  },
  en: {
    title: "Teaching | LaMoGe",
    description: "Laboratory participation in university teaching and advanced training.",
    eyebrow: "Training",
    pageTitle: "Teaching",
    pageDescription:
      "LaMoGe contributes to undergraduate and graduate teaching through courses, thesis supervision and methodological support in geosciences."
  }
}[locale];
---

<BaseLayout title={copy.title} description={copy.description} locale={locale} image="/images/gallery/IMG_3676.JPG">
  <Header locale={locale} navigation={content.navigation} />
  <main id="main-content" class="pb-14">
    <PageHero eyebrow={copy.eyebrow} title={copy.pageTitle} description={copy.pageDescription} image="/images/gallery/IMG_3676.JPG" />

    <section class="section shell">
      <div class="surface-panel">
        <div class="grid gap-5 lg:grid-cols-3">
          {teaching.map((item) => (
            <article class="card" data-reveal>
              <span class="pill">{localizeText(item.format, locale)}</span>
              <h2 class="mt-4 text-xl font-semibold text-[color:var(--ink-950)]">{localizeText(item.title, locale)}</h2>
              <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.description, locale)}</p>
              <p class="mt-4 text-sm text-[color:var(--ink-500)]">{localizeText(item.audience, locale)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} navigation={content.navigation} footer={content.footer} />
</BaseLayout>
