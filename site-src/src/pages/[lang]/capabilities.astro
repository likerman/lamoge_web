---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";
import facilitiesData from "../../data/facilities.json";
import activitiesData from "../../data/activities.json";
import { locales, localizeText, siteContent, type Locale } from "../../lib/i18n";
import type { ActivityItem, FacilityItem } from "../../types/content";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as Locale;
const content = siteContent[locale];
const facilities = facilitiesData as FacilityItem[];
const activities = (activitiesData as ActivityItem[]).slice(0, 4);

const copy = {
  es: {
    title: "Capacidades | LaMoGe",
    description: "Capacidades experimentales, analíticas y computacionales del laboratorio.",
    eyebrow: "Investigación",
    pageTitle: "Capacidades",
    pageDescription:
      "LaMoGe combina infraestructura experimental, procesamiento de datos y recursos computacionales para abordar problemas geológicos complejos con consistencia metodológica."
  },
  en: {
    title: "Capabilities | LaMoGe",
    description: "Experimental, analytical and computational capabilities of the laboratory.",
    eyebrow: "Research",
    pageTitle: "Capabilities",
    pageDescription:
      "LaMoGe combines experimental infrastructure, data processing and computational resources to address complex geological problems with methodological consistency."
  }
}[locale];
---

<BaseLayout title={copy.title} description={copy.description} locale={locale} image="/images/experiments/modelado02-1024x683.jpg">
  <Header locale={locale} navigation={content.navigation} />
  <main id="main-content" class="pb-14">
    <PageHero eyebrow={copy.eyebrow} title={copy.pageTitle} description={copy.pageDescription} image="/images/experiments/modelado02-1024x683.jpg" />

    <section class="section shell">
      <div class="surface-panel">
        <div class="grid gap-5 lg:grid-cols-3">
          {facilities.map((item) => (
            <article class="card overflow-hidden p-0" data-reveal>
              {item.image && <img src={item.image} alt="" class="aspect-[16/10] w-full object-cover" />}
              <div class="p-6">
                <span class="pill">{localizeText(item.category, locale)}</span>
                <h2 class="mt-4 text-xl font-semibold text-[color:var(--ink-950)]">{localizeText(item.name, locale)}</h2>
                <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.description, locale)}</p>
                <p class="mt-4 text-sm text-[color:var(--ink-500)]">{localizeText(item.use, locale)}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section shell">
      <div class="surface-panel">
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {activities.map((item) => (
            <article class="card" data-reveal>
              <span class="pill">{item.icon}</span>
              <h3 class="mt-4 text-lg font-semibold text-[color:var(--ink-950)]">{localizeText(item.title, locale)}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--ink-700)]">{localizeText(item.description, locale)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} navigation={content.navigation} footer={content.footer} />
</BaseLayout>
