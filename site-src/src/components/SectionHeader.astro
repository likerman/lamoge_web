---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-8 max-w-4xl" data-reveal>
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="section-title">{title}</h2>
  <p class="section-copy">{description}</p>
</div>
