---
import type { Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const pathname = Astro.url.pathname;
const esPath = pathname.replace(/^\/(es|en)(\/|$)/, "/es$2");
const enPath = pathname.replace(/^\/(es|en)(\/|$)/, "/en$2");
---

<div class="language-switcher" aria-label={locale === "es" ? "Selector de idioma" : "Language switcher"}>
  <a
    href={esPath}
    data-locale-link
    class:list={["language-pill", locale === "es" && "is-active"]}
    aria-current={locale === "es" ? "page" : undefined}
  >
    ES
  </a>
  <a
    href={enPath}
    data-locale-link
    class:list={["language-pill", locale === "en" && "is-active"]}
    aria-current={locale === "en" ? "page" : undefined}
  >
    EN
  </a>
</div>
