---
import type { Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div class="language-switcher inline-flex rounded-full border border-white/8 bg-white/6 p-1" aria-label={locale === "es" ? "Selector de idioma" : "Language switcher"}>
  <a
    href="/es/"
    class:list={[
      "rounded-full px-3 py-1.5 text-xs font-bold tracking-[0.16em] transition-colors",
      locale === "es" ? "bg-teal-400 text-ink-950" : "text-mist-300 hover:text-white"
    ]}
    aria-current={locale === "es" ? "page" : undefined}
  >
    ES
  </a>
  <a
    href="/en/"
    class:list={[
      "rounded-full px-3 py-1.5 text-xs font-bold tracking-[0.16em] transition-colors",
      locale === "en" ? "bg-teal-400 text-ink-950" : "text-mist-300 hover:text-white"
    ]}
    aria-current={locale === "en" ? "page" : undefined}
  >
    EN
  </a>
</div>
