---
import type { Locale } from "../lib/i18n";
import { siteContent } from "../lib/i18n";

interface Props {
  locale: Locale;
  navigation: {
    groups: Array<{ label: string; path?: string; items?: Array<{ label: string; path: string }> }>;
    search: string;
    intranet: string;
  };
  footer: {
    tagline: string;
    quickLinks: string;
    resources: string;
    contact: string;
    backToTop: string;
    credits: string;
  };
}

const { locale, navigation, footer } = Astro.props;
const institutionEmail = siteContent[locale].institution.email;

const navLinks = navigation.groups.map((group) => ({
  path: `/${locale}${group.path ?? group.items?.[0]?.path ?? "/"}`,
  label: group.label
}));

const resourceLinks = [
  { path: `/${locale}/search/`, label: navigation.search },
  { path: `/${locale}/news/`, label: locale === "es" ? "Novedades" : "News" },
  { path: `/${locale}/contact/`, label: locale === "es" ? "Contacto" : "Contact" },
  { path: "/intranet/", label: navigation.intranet }
];
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div class="footer-brand">
      <a href={`/${locale}/`} class="brand-link brand-link-footer">
        <img src="/brand/lamoge-logo.svg" alt="LaMoGe" class="brand-logo" />
      </a>
      <p class="footer-kicker">IDEAN · UBA · CONICET</p>
      <p class="footer-tagline">{footer.tagline}</p>
      <p class="footer-credits">{footer.credits}</p>
    </div>

    <div>
      <h2 class="footer-title">{footer.quickLinks}</h2>
      <nav class="footer-link-list" aria-label={footer.quickLinks}>
        {navLinks.map((link) => (
          <a href={link.path}>{link.label}</a>
        ))}
      </nav>
    </div>

    <div>
      <h2 class="footer-title">{footer.resources}</h2>
      <nav class="footer-link-list" aria-label={footer.resources}>
        {resourceLinks.map((link) => (
          <a href={link.path}>{link.label}</a>
        ))}
      </nav>
    </div>

    <div>
      <h2 class="footer-title">{footer.contact}</h2>
      <div class="footer-contact">
        <p>{institutionEmail}</p>
        <p>Ciudad Universitaria, Pabellón II, Buenos Aires, Argentina</p>
        <p>IDEAN · UBA · CONICET</p>
        <a class="footer-back-link" href="#top">{footer.backToTop}</a>
      </div>
    </div>
  </div>
</footer>
