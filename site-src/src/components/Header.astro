---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Locale } from "../lib/i18n";

interface NavItem {
  label: string;
  path?: string;
  items?: Array<{ label: string; path: string }>;
}

interface Props {
  locale: Locale;
  navigation: {
    groups: NavItem[];
    search: string;
    intranet: string;
    openMenu: string;
    closeMenu: string;
    primaryCta: string;
    utility?: Array<{ label: string; path: string }>;
  };
}

const { locale, navigation } = Astro.props;
const pathname = Astro.url.pathname;
const homePath = `/${locale}/`;
const navId = "site-navigation";
const isItemActive = (path?: string) => (path ? pathname === `/${locale}${path}` || pathname.startsWith(`/${locale}${path}`) : false);
const isGroupActive = (group: NavItem) =>
  (group.path && isItemActive(group.path)) ||
  group.items?.some((item) => isItemActive(item.path));

const getGroupItems = (group: NavItem) => {
  const items = group.items ? [...group.items] : [];
  if (group.path) {
    items.unshift({
      label: locale === "es" ? `Ver ${group.label}` : `View ${group.label}`,
      path: group.path
    });
  }
  return items;
};
---

<header id="main-header" class="site-header">
  <div class="shell site-header-shell">
    <div class="site-header-bar">
      <a href={homePath} class="brand-lockup" aria-label="LaMoGe">
        <img src="/brand/lamoge-logo.svg" alt="LaMoGe" />
        <span class="brand-copy">
          <span class="brand-name">LaMoGe</span>
          <span class="brand-kicker">{locale === "es" ? "Laboratorio de Modelado Geológico" : "Geological Modelling Laboratory"}</span>
        </span>
      </a>

      <button
        class="menu-toggle"
        type="button"
        aria-controls={navId}
        aria-expanded="false"
        aria-label={navigation.openMenu}
        data-open-label={navigation.openMenu}
        data-close-label={navigation.closeMenu}
      >
        <svg class="menu-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
        <span class="menu-toggle-label">{navigation.openMenu}</span>
      </button>

      <div class="site-nav" id={navId}>
        <div class="site-nav-panel">
          <nav aria-label={locale === "es" ? "Navegación principal" : "Primary navigation"}>
            <ul class="site-nav-list">
              {navigation.groups.map((group) => (
                <li>
                  {group.items ? (
                    <details class="nav-group" open={isGroupActive(group) && undefined}>
                      <summary class:list={["nav-summary", isGroupActive(group) && "is-active"]}>
                        {group.label}
                        <svg viewBox="0 0 20 20" width="14" height="14" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 011.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"></path>
                        </svg>
                      </summary>
                      <div class="nav-submenu">
                        {getGroupItems(group).map((item) => (
                          <a href={`/${locale}${item.path}`} class:list={[isItemActive(item.path) && "is-active"]}>
                            {item.label}
                          </a>
                        ))}
                      </div>
                    </details>
                  ) : (
                    <a href={`/${locale}${group.path}`} class:list={["nav-link", isItemActive(group.path) && "is-active"]}>
                      {group.label}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </nav>

          <div class="header-actions">
            <div class="header-utility-links" aria-label={locale === "es" ? "Accesos rápidos" : "Quick links"}>
              {(navigation.utility ?? []).map((item) => (
                <a class="header-utility-link" href={`/${locale}${item.path}`}>{item.label}</a>
              ))}
              <a class="header-utility-link" href="/intranet/">{navigation.intranet}</a>
            </div>
            <LanguageSwitcher locale={locale} />
            <a href={`/${locale}/contact/`} class="button-primary">{navigation.primaryCta}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
