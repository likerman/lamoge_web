---
interface Props {
  locale: "es" | "en";
  hero: {
    eyebrow: string;
    title: string;
    subtitle: string;
    primaryCta: string;
    secondaryCta: string;
    stats: string[];
  };
}

const { locale, hero } = Astro.props;
---

<section class="home-hero">
  <div class="home-hero-art" aria-hidden="true">
    <div class="hero-orbit hero-orbit-a"></div>
    <div class="hero-orbit hero-orbit-b"></div>
    <div class="hero-grid"></div>
    <div class="hero-strata"></div>
  </div>

  <div class="shell home-hero-shell">
    <div class="home-hero-copy" data-reveal>
      <p class="eyebrow">{hero.eyebrow}</p>
      <h1 class="hero-title">{hero.title}</h1>
      <p class="hero-subtitle">{hero.subtitle}</p>
      <div class="hero-actions">
        <a href={`/${locale}/research-lines/`} class="button-primary">{hero.primaryCta}</a>
        <a href={`/${locale}/contact/`} class="button-secondary button-secondary-dark">{hero.secondaryCta}</a>
      </div>
      <div class="hero-kpis">
        <span class="pill">{locale === "es" ? "Modelado geológico · Tectónica · Geodinámica" : "Geological modelling · Tectonics · Geodynamics"}</span>
        <div class="hero-kpi-row">
          <div class="hero-kpi">
            <strong>2004</strong>
            <span>{locale === "es" ? "Trayectoria activa" : "Active trajectory"}</span>
          </div>
          <div class="hero-kpi">
            <strong>ES / EN</strong>
            <span>{locale === "es" ? "Portal bilingüe" : "Bilingual platform"}</span>
          </div>
          <div class="hero-kpi">
            <strong>UBA + CONICET</strong>
            <span>{locale === "es" ? "Articulación institucional" : "Institutional articulation"}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="home-hero-aside" data-reveal>
      <div class="hero-media-frame">
        <img src="/images/gallery/DSC_0320.JPG" alt="" class="hero-media-main" />
        <div class="hero-media-secondary">
          <img src="/images/gallery/DJI_0664.JPG" alt="" />
        </div>
      </div>

      <div class="hero-stat-grid">
        {hero.stats.map((item, index) => (
          <article class="hero-stat-card">
            <strong>{index === 0 ? "01" : index === 1 ? "02" : "03"}</strong>
            <span>{item}</span>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
